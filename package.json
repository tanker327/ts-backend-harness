{
  "name": "ts-backend-harness",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "lefthook": "^2.1.4",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "bunx biome check .",
    "format": "bunx biome format --write .",
    "bootstrap": "bash scripts/bootstrap.sh",
    "init": "bash scripts/init.sh",
    "quality": "bun run scripts/update-quality.ts",
    "harness-metrics": "bun run scripts/update-harness-metrics.ts",
    "db:migrate": "bash scripts/migrate.sh",
    "worker": "bun run src/worker-entry.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.2.3",
    "postgres": "^3.4.5",
    "better-auth": "^1.5.6",
    "bullmq": "^5.71.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "hono-pino": "^0.10.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  }
}
